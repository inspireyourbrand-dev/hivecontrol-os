{
  "$schema": "hiveclaw-config-v0.1",
  "version": "0.1.0",
  "product": "HiveClaw",
  "brand": "HivePowered.Ai",
  "upstream": {
    "repo": "https://github.com/openclaw/openclaw.git",
    "branch": "main",
    "syncStrategy": "merge",
    "syncCadence": "weekly"
  },
  "hivecontrol": {
    "enabled": true,
    "servePath": "/__hiveclaw__/hivecontrol/",
    "defaultTheme": "dark",
    "screens": [
      "dashboard",
      "tasks",
      "calendar",
      "memory",
      "projects",
      "documents",
      "team",
      "office"
    ]
  },
  "hiveworkflow": {
    "enabled": false,
    "status": "coming-soon",
    "servePath": "/__hiveclaw__/hiveworkflow/"
  },
  "gateway": {
    "wsPort": 18789,
    "wsHost": "127.0.0.1",
    "autoReconnect": true,
    "reconnectInterval": 3000,
    "maxReconnectAttempts": 50
  },
  "governor": {
    "enabled": true,
    "maxConcurrentExternalCalls": 1,
    "minDelayBetweenCalls": 2000,
    "backoff": {
      "firstHit": 60000,
      "secondHit": 900000,
      "thirdHit": "offline"
    }
  },
  "agents": {
    "hierarchy": "agents/AGENTS.md",
    "defaultOrchestrator": "orion"
  }
}
